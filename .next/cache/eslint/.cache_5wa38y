 create components during render\n\nComponents created during render will reset their state each time they are created. Declare components outside of render.\n\n/Users/anilbobba/Desktop/railway-exam-portal/src/components/layout/AppSideBar.tsx:176:10\n  174 |           {collapsed ? <ChevronRight size={12} /> : <X size={12} />}\n  175 |         </button>\n> 176 |         <SidebarContent />\n      |          ^^^^^^^^^^^^^^ This component is created during render\n  177 |       </aside>\n  178 |\n  179 |       {/* Mobile Overlay */}\n\n/Users/anilbobba/Desktop/railway-exam-portal/src/components/layout/AppSideBar.tsx:45:26\n   43 |   };\n   44 |\n>  45 |   const SidebarContent = () => (\n      |                          ^^^^^^^\n>  46 |     <div className=\"flex flex-col h-full\">\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n>  47 |       {/* Logo */}\n      …\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 159 |     </div>\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 160 |   );\n      | ^^^^ The component is created during render here\n  161 |\n  162 |   return (\n  163 |     <div className=\"flex h-screen bg-gray-50\">","Error: Cannot create components during render\n\nComponents created during render will reset their state each time they are created. Declare components outside of render.\n\n/Users/anilbobba/Desktop/railway-exam-portal/src/components/layout/AppSideBar.tsx:189:10\n  187 |         mobileOpen ? \"translate-x-0\" : \"-translate-x-full\"\n  188 |       )}>\n> 189 |         <SidebarContent />\n      |          ^^^^^^^^^^^^^^ This component is created during render\n  190 |       </aside>\n  191 |\n  192 |       {/* Main Content Area */}\n\n/Users/anilbobba/Desktop/railway-exam-portal/src/components/layout/AppSideBar.tsx:45:26\n   43 |   };\n   44 |\n>  45 |   const SidebarContent = () => (\n      |                          ^^^^^^^\n>  46 |     <div className=\"flex flex-col h-full\">\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n>  47 |       {/* Logo */}\n      …\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 159 |     </div>\n      | ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\n> 160 |   );\n      | ^^^^ The component is created during render here\n  161 |\n  162 |   return (\n  163 |     <div className=\"flex h-screen bg-gray-50\">",["383","384","385","386"],["387","388","389","390"],["391","392","393","394"],"react-hooks/set-state-in-effect","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/anilbobba/Desktop/railway-exam-portal/src/components/tests/TakeTestPage.tsx:82:7\n  80 |   useEffect(() => {\n  81 |     if (test && timeLeft === null) {\n> 82 |       setTimeLeft(test.duration * 60);\n     |       ^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  83 |     }\n  84 |   }, [test, timeLeft]);\n  85 |","Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\n/Users/anilbobba/Desktop/railway-exam-portal/src/components/tests/TakeTestPage.tsx:124:41\n  122 |   useEffect(() => {\n  123 |     if (submitted || timeLeft === null || timeLeft <= 0) {\n> 124 |       if (timeLeft === 0 && !submitted) handleSubmit();\n      |                                         ^^^^^^^^^^^^ Avoid calling setState() directly within an effect\n  125 |       return;\n  126 |     }\n  127 |     const timer = setInterval(() => setTimeLeft(p => (p ?? 1) - 1), 1000);","react-hooks/purity","Error: Cannot call impure function during render\n\n`Math.random` is an impure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\n/Users/anilbobba/Desktop/railway-exam-portal/src/components/ui/sidebar.tsx:613:26\n  611 |   // Random width between 50 to 90%.\n  612 |   const width = React.useMemo(() => {\n> 613 |     return `${Math.floor(Math.random() * 40) + 50}%`\n      |                          ^^^^^^^^^^^^^ Cannot call impure function\n  614 |   }, [])\n  615 |\n  616 |   return (",{"messageId":"395","data":"396","fix":"397","desc":"398"},{"messageId":"399","data":"400","fix":"401","desc":"402"},{"messageId":"399","data":"403","fix":"404","desc":"405"},{"messageId":"399","data":"406","fix":"407","desc":"408"},{"messageId":"399","data":"409","fix":"410","desc":"411"},{"messageId":"399","data":"412","fix":"413","desc":"414"},{"messageId":"399","data":"415","fix":"416","desc":"417"},{"messageId":"399","data":"418","fix":"419","desc":"420"},{"messageId":"399","data":"421","fix":"422","desc":"423"},{"messageId":"399","data":"424","fix":"425","desc":"414"},{"messageId":"399","data":"426","fix":"427","des